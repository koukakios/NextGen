#include <Arduino.h>
#include <string.h>

#ifndef ARDUINO_GIGA
#error This sketch is written for Arduino GIGA R1 WiFi.
#endif

// --------------------------------------------------
// Wheelchair skeleton for 2 VESCs over CAN bus
// Arduino GIGA + PlatformIO
//
// PC protocol over Serial:
//
// Required order:
//   1. <EN,1>
//   2. <MODE,2> or <MODE,5> or <MODE,10>
//   3. <MOVE,F/B/L/R/S> every 50 ms
//
// Safety:
//   - After <EN,1>, Arduino expects valid PC commands.
//   - If no valid command is received for 500 ms,
//     the chair stops, drive disables, and mode is cleared.
//   - After timeout, PC must send <EN,1> again.
//
// VESC setup required:
//   - App Settings -> General -> CAN Mode = VESC
//   - Give the two VESCs different VESC IDs
//   - Match LEFT_VESC_ID and RIGHT_VESC_ID below
//   - Recommended: enable CAN Status Messages if you want <TEL>
// --------------------------------------------------

constexpr bool DRY_RUN = true;

// PC communication port
#define PC_SERIAL Serial

// --------------------------------------------------
// Motor relay / brake release control
// --------------------------------------------------

// Course note: DS-9 pin 4 is Analog 1 on the GIGA shield.
// Pulling this pin LOW activates the relay, connects the motors,
// and releases the brakes. This consumes about 1 A, so keep it
// active only while the chair is intentionally enabled.
constexpr uint8_t MOTOR_RELAY_PIN = A1;
constexpr uint8_t MOTOR_RELAY_ACTIVE_LEVEL = LOW;
constexpr uint8_t MOTOR_RELAY_INACTIVE_LEVEL = HIGH;

bool motorRelayActive = false;

// --------------------------------------------------
// CAN configuration
// --------------------------------------------------

constexpr uint32_t VESC_CAN_BITRATE = 500000;

// Change these to match App Settings -> General -> VESC ID in VESC Tool.
constexpr uint8_t LEFT_VESC_ID  = 1;
constexpr uint8_t RIGHT_VESC_ID = 2;

// Set to true if one motor direction is physically reversed.
constexpr bool INVERT_LEFT_MOTOR  = false;
constexpr bool INVERT_RIGHT_MOTOR = false;

// ACANFD_GIGA_R1 requires these constants before including the library.
// Only FDCAN1 is used here. FDCAN2 message RAM is set to 0.
static const uint32_t FDCAN1_MESSAGE_RAM_WORD_SIZE = 1000;
static const uint32_t FDCAN2_MESSAGE_RAM_WORD_SIZE = 0;

#include <ACANFD_GIGA_R1.h>

#define VESC_CAN fdcan1

bool canReady = false;

// --------------------------------------------------
// Timing
// --------------------------------------------------

constexpr unsigned long EXPECTED_PC_COMMAND_PERIOD_MS = 50;
constexpr unsigned long PC_TIMEOUT_MS = 500;

constexpr unsigned long KEEPALIVE_MS = 100;
constexpr unsigned long STOP_BEFORE_CHANGE_MS = 150;

// --------------------------------------------------
// Motion and mode states
// --------------------------------------------------

enum MotionState {
  STOPPED,
  FORWARD,
  REVERSE,
  LEFT,
  RIGHT
};

enum DrivingMode {
  MODE_2_KMH,
  MODE_5_KMH,
  MODE_10_KMH
};

bool driveEnabled = false;
bool modeSelected = false;
bool timeoutLatched = false;

MotionState motion = STOPPED;
DrivingMode drivingMode = MODE_2_KMH;

float leftTarget = 0.0f;
float rightTarget = 0.0f;

unsigned long lastValidPcCommandMs = 0;
unsigned long lastKeepAliveMs = 0;

bool transitionPending = false;
unsigned long transitionStartMs = 0;

float pendingLeftTarget = 0.0f;
float pendingRightTarget = 0.0f;
MotionState pendingMotion = STOPPED;

// --------------------------------------------------
// Duty presets
//
// These are starting values.
// They do NOT automatically guarantee exact real km/h.
// You must tune them on the real wheelchair.
// --------------------------------------------------

constexpr float DUTY_2_KMH  = 0.05f;
constexpr float DUTY_5_KMH  = 0.10f;
constexpr float DUTY_10_KMH = 0.70f;

constexpr float TURN_DUTY_FACTOR = 0.80f;
constexpr float REVERSE_DUTY_FACTOR = 0.70f;

// --------------------------------------------------
// PC frame buffer
// --------------------------------------------------

constexpr size_t PC_RX_BUFFER_SIZE = 64;
char pcRxBuffer[PC_RX_BUFFER_SIZE];
size_t pcRxIndex = 0;
bool receivingFrame = false;

// --------------------------------------------------
// VESC CAN packet IDs used here
// --------------------------------------------------

enum VescCanPacketId : uint8_t {
  CAN_PACKET_SET_DUTY = 0,
  CAN_PACKET_STATUS = 9,
  CAN_PACKET_STATUS_2 = 14,
  CAN_PACKET_STATUS_3 = 15,
  CAN_PACKET_STATUS_4 = 16,
  CAN_PACKET_STATUS_5 = 27,
  CAN_PACKET_STATUS_6 = 58
};

// --------------------------------------------------
// Telemetry cache from VESC CAN status frames
// --------------------------------------------------

struct VescTelemetry {
  bool status1Valid = false;
  bool status5Valid = false;

  int32_t rpm = 0;
  float motorCurrentA = 0.0f;
  float duty = 0.0f;

  int32_t tachometer = 0;
  float inputVoltage = 0.0f;

  unsigned long lastStatus1Ms = 0;
  unsigned long lastStatus5Ms = 0;
};

VescTelemetry leftTelemetry;
VescTelemetry rightTelemetry;

// --------------------------------------------------
// Helper functions
// --------------------------------------------------

const char* motionToString(MotionState s) {
  switch (s) {
    case STOPPED: return "STOP";
    case FORWARD: return "FORWARD";
    case REVERSE: return "REVERSE";
    case LEFT:    return "LEFT";
    case RIGHT:   return "RIGHT";
    default:      return "UNKNOWN";
  }
}

const char* drivingModeToString(DrivingMode m) {
  switch (m) {
    case MODE_2_KMH:  return "2KMH";
    case MODE_5_KMH:  return "5KMH";
    case MODE_10_KMH: return "10KMH";
    default:          return "UNKNOWN";
  }
}

float getDriveDuty() {
  switch (drivingMode) {
    case MODE_2_KMH:
      return DUTY_2_KMH;

    case MODE_5_KMH:
      return DUTY_5_KMH;

    case MODE_10_KMH:
      return DUTY_10_KMH;

    default:
      return DUTY_2_KMH;
  }
}

float getTurnDuty() {
  return getDriveDuty() * TURN_DUTY_FACTOR;
}

float getReverseDuty() {
  return getDriveDuty() * REVERSE_DUTY_FACTOR;
}

char toUpperChar(char c) {
  if (c >= 'a' && c <= 'z') {
    return c - 32;
  }

  return c;
}

bool equalsIgnoreCase(const char* a, const char* b) {
  if (a == nullptr || b == nullptr) {
    return false;
  }

  while (*a && *b) {
    char ca = toUpperChar(*a);
    char cb = toUpperChar(*b);

    if (ca != cb) {
      return false;
    }

    a++;
    b++;
  }

  return *a == '\0' && *b == '\0';
}

float clampDuty(float duty) {
  if (duty > 1.0f) {
    return 1.0f;
  }

  if (duty < -1.0f) {
    return -1.0f;
  }

  return duty;
}

void markValidPcCommand() {
  lastValidPcCommandMs = millis();
}

void bufferAppendInt32(uint8_t* buffer, int32_t value) {
  buffer[0] = uint8_t((value >> 24) & 0xFF);
  buffer[1] = uint8_t((value >> 16) & 0xFF);
  buffer[2] = uint8_t((value >> 8) & 0xFF);
  buffer[3] = uint8_t(value & 0xFF);
}

int16_t bufferGetInt16(const uint8_t* buffer) {
  return int16_t((uint16_t(buffer[0]) << 8) | uint16_t(buffer[1]));
}

int32_t bufferGetInt32(const uint8_t* buffer) {
  return int32_t(
    (uint32_t(buffer[0]) << 24) |
    (uint32_t(buffer[1]) << 16) |
    (uint32_t(buffer[2]) << 8) |
    uint32_t(buffer[3])
  );
}

// --------------------------------------------------
// Protocol reply helpers
// --------------------------------------------------

void pcAck(const char* message) {
  PC_SERIAL.print("<ACK,");
  PC_SERIAL.print(message);
  PC_SERIAL.println(">");
}

void pcErr(const char* message) {
  PC_SERIAL.print("<ERR,");
  PC_SERIAL.print(message);
  PC_SERIAL.println(">");
}

void pcEvent(const char* message) {
  PC_SERIAL.print("<EVT,");
  PC_SERIAL.print(message);
  PC_SERIAL.println(">");
}

void pcWarn(const char* message) {
  PC_SERIAL.print("<WARN,");
  PC_SERIAL.print(message);
  PC_SERIAL.println(">");
}

// --------------------------------------------------
// Motor relay / brake release helpers
// --------------------------------------------------

void setMotorRelay(bool active) {
  digitalWrite(MOTOR_RELAY_PIN, active ? MOTOR_RELAY_ACTIVE_LEVEL : MOTOR_RELAY_INACTIVE_LEVEL);
  motorRelayActive = active;

  PC_SERIAL.print("<EVT,MOTOR_RELAY=");
  PC_SERIAL.print(motorRelayActive ? 1 : 0);
  PC_SERIAL.println(">");
}

void setupMotorRelay() {
  // Important safety default: relay OFF, brakes engaged, motors disconnected.
  digitalWrite(MOTOR_RELAY_PIN, MOTOR_RELAY_INACTIVE_LEVEL);
  pinMode(MOTOR_RELAY_PIN, OUTPUT);
  digitalWrite(MOTOR_RELAY_PIN, MOTOR_RELAY_INACTIVE_LEVEL);
  motorRelayActive = false;

  PC_SERIAL.println("<BOOT,MOTOR_RELAY_OFF>");
}

// --------------------------------------------------
// Status
// --------------------------------------------------

void sendStatusFrame() {
  PC_SERIAL.print("<STAT,EN=");
  PC_SERIAL.print(driveEnabled ? 1 : 0);

  PC_SERIAL.print(",MODE_SET=");
  PC_SERIAL.print(modeSelected ? 1 : 0);

  PC_SERIAL.print(",MODE=");
  PC_SERIAL.print(modeSelected ? drivingModeToString(drivingMode) : "NONE");

  PC_SERIAL.print(",MOTION=");
  PC_SERIAL.print(motionToString(motion));

  PC_SERIAL.print(",L=");
  PC_SERIAL.print(leftTarget, 3);

  PC_SERIAL.print(",R=");
  PC_SERIAL.print(rightTarget, 3);

  PC_SERIAL.print(",PENDING=");
  PC_SERIAL.print(transitionPending ? 1 : 0);

  PC_SERIAL.print(",TIMEOUT=");
  PC_SERIAL.print(timeoutLatched ? 1 : 0);

  PC_SERIAL.print(",CAN_READY=");
  PC_SERIAL.print(canReady ? 1 : 0);

  PC_SERIAL.print(",RELAY=");
  PC_SERIAL.print(motorRelayActive ? 1 : 0);

  PC_SERIAL.print(",LEFT_ID=");
  PC_SERIAL.print(LEFT_VESC_ID);

  PC_SERIAL.print(",RIGHT_ID=");
  PC_SERIAL.print(RIGHT_VESC_ID);

  PC_SERIAL.print(",CAN_BITRATE=");
  PC_SERIAL.print(VESC_CAN_BITRATE);

  PC_SERIAL.print(",TIMEOUT_MS=");
  PC_SERIAL.print(PC_TIMEOUT_MS);

  PC_SERIAL.print(",EXPECTED_PERIOD_MS=");
  PC_SERIAL.print(EXPECTED_PC_COMMAND_PERIOD_MS);

  PC_SERIAL.print(",DRY=");
  PC_SERIAL.print(DRY_RUN ? 1 : 0);

  PC_SERIAL.println(">");
}

// --------------------------------------------------
// VESC CAN functions
// --------------------------------------------------

bool sendVescCanFrame(uint8_t controllerId, VescCanPacketId packetId, const uint8_t* data, uint8_t len) {
  if (len > 8) {
    pcErr("CAN_FRAME_TOO_LONG");
    return false;
  }

  if (DRY_RUN) {
    PC_SERIAL.print("<DRY,CAN,ID=");
    PC_SERIAL.print(controllerId);
    PC_SERIAL.print(",CMD=");
    PC_SERIAL.print(uint8_t(packetId));
    PC_SERIAL.print(",LEN=");
    PC_SERIAL.print(len);
    PC_SERIAL.println(">");
    return true;
  }

  if (!canReady) {
    pcErr("CAN_NOT_READY");
    return false;
  }

  CANFDMessage frame;
  frame.id = uint32_t(controllerId) | (uint32_t(packetId) << 8);
  frame.ext = true;
  frame.type = CANFDMessage::CAN_DATA;  // Classic CAN 2.0B data frame, not CAN FD.
  frame.len = len;

  for (uint8_t i = 0; i < len; i++) {
    frame.data[i] = data[i];
  }

  uint32_t sendStatus = VESC_CAN.tryToSendReturnStatusFD(frame);

  if (sendStatus != 0) {
    PC_SERIAL.print("<ERR,CAN_SEND_FAILED,STATUS=0x");
    PC_SERIAL.print(sendStatus, HEX);
    PC_SERIAL.println(">");
    return false;
  }

  return true;
}

bool sendVescDuty(uint8_t controllerId, float duty) {
  duty = clampDuty(duty);

  uint8_t buffer[4];
  int32_t scaledDuty = int32_t(duty * 100000.0f);
  bufferAppendInt32(buffer, scaledDuty);

  return sendVescCanFrame(controllerId, CAN_PACKET_SET_DUTY, buffer, sizeof(buffer));
}

void sendLeftCommand(float duty) {
  if (INVERT_LEFT_MOTOR) {
    duty = -duty;
  }

  if (DRY_RUN) {
    PC_SERIAL.print("<DRY,L,DUTY=");
    PC_SERIAL.print(duty, 3);
    PC_SERIAL.println(">");
  }

  sendVescDuty(LEFT_VESC_ID, duty);
}

void sendRightCommand(float duty) {
  if (INVERT_RIGHT_MOTOR) {
    duty = -duty;
  }

  if (DRY_RUN) {
    PC_SERIAL.print("<DRY,R,DUTY=");
    PC_SERIAL.print(duty, 3);
    PC_SERIAL.println(">");
  }

  sendVescDuty(RIGHT_VESC_ID, duty);
}

void sendKeepaliveBoth() {
  // VESC CAN timeout is prevented by repeatedly sending the current duty command.
  sendLeftCommand(leftTarget);
  sendRightCommand(rightTarget);
}

void handleVescStatusFrame(const CANFDMessage& frame) {
  if (!frame.ext) {
    return;
  }

  if (frame.type != CANFDMessage::CAN_DATA && frame.type != CANFDMessage::CANFD_NO_BIT_RATE_SWITCH && frame.type != CANFDMessage::CANFD_WITH_BIT_RATE_SWITCH) {
    return;
  }

  uint8_t controllerId = uint8_t(frame.id & 0xFF);
  uint8_t commandId = uint8_t((frame.id >> 8) & 0xFF);

  VescTelemetry* telemetry = nullptr;

  if (controllerId == LEFT_VESC_ID) {
    telemetry = &leftTelemetry;
  } else if (controllerId == RIGHT_VESC_ID) {
    telemetry = &rightTelemetry;
  } else {
    return;
  }

  if (commandId == CAN_PACKET_STATUS && frame.len >= 8) {
    telemetry->rpm = bufferGetInt32(&frame.data[0]);
    telemetry->motorCurrentA = float(bufferGetInt16(&frame.data[4])) / 10.0f;
    telemetry->duty = float(bufferGetInt16(&frame.data[6])) / 1000.0f;
    telemetry->status1Valid = true;
    telemetry->lastStatus1Ms = millis();
    return;
  }

  if (commandId == CAN_PACKET_STATUS_5 && frame.len >= 6) {
    telemetry->tachometer = bufferGetInt32(&frame.data[0]);
    telemetry->inputVoltage = float(bufferGetInt16(&frame.data[4])) / 10.0f;
    telemetry->status5Valid = true;
    telemetry->lastStatus5Ms = millis();
    return;
  }
}

void readCanBus() {
  if (DRY_RUN || !canReady) {
    return;
  }

  CANFDMessage frame;

  // Limit messages processed per loop so Serial parsing and timeout checks are never starved.
  for (uint8_t i = 0; i < 20 && VESC_CAN.receiveFD0(frame); i++) {
    handleVescStatusFrame(frame);
  }

  for (uint8_t i = 0; i < 20 && VESC_CAN.receiveFD1(frame); i++) {
    handleVescStatusFrame(frame);
  }
}

// --------------------------------------------------
// Movement mapping
// --------------------------------------------------

bool getTargetsForMotion(MotionState wantedMotion, float &left, float &right) {
  float driveDuty = getDriveDuty();
  float reverseDuty = getReverseDuty();
  float turnDuty = getTurnDuty();

  switch (wantedMotion) {
    case FORWARD:
      left = driveDuty;
      right = driveDuty;
      return true;

    case REVERSE:
      left = -reverseDuty;
      right = -reverseDuty;
      return true;

    case LEFT:
      left = -turnDuty;
      right = turnDuty;
      return true;

    case RIGHT:
      left = turnDuty;
      right = -turnDuty;
      return true;

    case STOPPED:
      left = 0.0f;
      right = 0.0f;
      return true;

    default:
      left = 0.0f;
      right = 0.0f;
      return false;
  }
}

// --------------------------------------------------
// Motor state functions
// --------------------------------------------------

void rawStopMotors() {
  leftTarget = 0.0f;
  rightTarget = 0.0f;
  motion = STOPPED;

  sendLeftCommand(0.0f);
  sendRightCommand(0.0f);

  pcEvent("MOTORS_STOPPED");
}

void stopMotors() {
  transitionPending = false;
  rawStopMotors();
}

void applyMotors(float left, float right, MotionState newMotion) {
  leftTarget = left;
  rightTarget = right;
  motion = newMotion;

  sendLeftCommand(leftTarget);
  sendRightCommand(rightTarget);

  PC_SERIAL.print("<EVT,MOTION=");
  PC_SERIAL.print(motionToString(motion));
  PC_SERIAL.print(",L=");
  PC_SERIAL.print(leftTarget, 3);
  PC_SERIAL.print(",R=");
  PC_SERIAL.print(rightTarget, 3);
  PC_SERIAL.println(">");
}

void requestMotion(float left, float right, MotionState newMotion) {
  if (!driveEnabled) {
    pcErr("ENABLE_FIRST");
    return;
  }

  if (!modeSelected && newMotion != STOPPED) {
    pcErr("MODE_FIRST");
    return;
  }

  if (transitionPending) {
    pendingLeftTarget = left;
    pendingRightTarget = right;
    pendingMotion = newMotion;

    PC_SERIAL.print("<EVT,PENDING_REPLACED,MOTION=");
    PC_SERIAL.print(motionToString(pendingMotion));
    PC_SERIAL.println(">");

    return;
  }

  if (motion == STOPPED) {
    applyMotors(left, right, newMotion);
    return;
  }

  if (motion == newMotion) {
    applyMotors(left, right, newMotion);
    return;
  }

  PC_SERIAL.print("<EVT,MOTION_CHANGE,FROM=");
  PC_SERIAL.print(motionToString(motion));
  PC_SERIAL.print(",TO=");
  PC_SERIAL.print(motionToString(newMotion));
  PC_SERIAL.println(">");

  rawStopMotors();

  pendingLeftTarget = left;
  pendingRightTarget = right;
  pendingMotion = newMotion;

  transitionPending = true;
  transitionStartMs = millis();
}

void requestMotionState(MotionState wantedMotion) {
  float left = 0.0f;
  float right = 0.0f;

  if (!getTargetsForMotion(wantedMotion, left, right)) {
    pcErr("INVALID_MOTION");
    return;
  }

  requestMotion(left, right, wantedMotion);
}

void processPendingTransition() {
  if (!transitionPending) {
    return;
  }

  if (!driveEnabled) {
    transitionPending = false;
    return;
  }

  if (millis() - transitionStartMs >= STOP_BEFORE_CHANGE_MS) {
    transitionPending = false;
    applyMotors(pendingLeftTarget, pendingRightTarget, pendingMotion);
  }
}

// --------------------------------------------------
// Drive and mode control
// --------------------------------------------------

void enableDrive() {
  driveEnabled = true;
  modeSelected = false;
  timeoutLatched = false;
  transitionPending = false;

  setMotorRelay(true);

  markValidPcCommand();
  rawStopMotors();

  pcAck("EN,1");
  pcEvent("WAITING_FOR_MODE");
}

void disableDrive() {
  stopMotors();
  setMotorRelay(false);

  driveEnabled = false;
  modeSelected = false;
  transitionPending = false;

  markValidPcCommand();

  pcAck("EN,0");
}

void setDrivingMode(DrivingMode newMode) {
  if (!driveEnabled) {
    pcErr("ENABLE_FIRST");
    return;
  }

  drivingMode = newMode;
  modeSelected = true;

  // Safer behavior:
  // if mode changes while moving, stop first.
  if (motion != STOPPED || transitionPending) {
    stopMotors();
  }

  markValidPcCommand();

  PC_SERIAL.print("<ACK,MODE,");
  PC_SERIAL.print(drivingModeToString(drivingMode));
  PC_SERIAL.println(">");

  PC_SERIAL.print("<EVT,BASE_DUTY=");
  PC_SERIAL.print(getDriveDuty(), 3);
  PC_SERIAL.println(">");
}

// --------------------------------------------------
// Telemetry
// --------------------------------------------------

void printTelemetrySide(const char* prefix, const VescTelemetry& telemetry) {
  unsigned long now = millis();

  PC_SERIAL.print(",");
  PC_SERIAL.print(prefix);
  PC_SERIAL.print("_OK=");
  PC_SERIAL.print(telemetry.status1Valid ? 1 : 0);

  if (telemetry.status1Valid) {
    PC_SERIAL.print(",");
    PC_SERIAL.print(prefix);
    PC_SERIAL.print("_AGE_MS=");
    PC_SERIAL.print(now - telemetry.lastStatus1Ms);

    PC_SERIAL.print(",");
    PC_SERIAL.print(prefix);
    PC_SERIAL.print("_RPM=");
    PC_SERIAL.print(telemetry.rpm);

    PC_SERIAL.print(",");
    PC_SERIAL.print(prefix);
    PC_SERIAL.print("_CUR_A=");
    PC_SERIAL.print(telemetry.motorCurrentA, 1);

    PC_SERIAL.print(",");
    PC_SERIAL.print(prefix);
    PC_SERIAL.print("_DUTY=");
    PC_SERIAL.print(telemetry.duty, 3);
  }

  PC_SERIAL.print(",");
  PC_SERIAL.print(prefix);
  PC_SERIAL.print("_VIN_OK=");
  PC_SERIAL.print(telemetry.status5Valid ? 1 : 0);

  if (telemetry.status5Valid) {
    PC_SERIAL.print(",");
    PC_SERIAL.print(prefix);
    PC_SERIAL.print("_VIN_AGE_MS=");
    PC_SERIAL.print(now - telemetry.lastStatus5Ms);

    PC_SERIAL.print(",");
    PC_SERIAL.print(prefix);
    PC_SERIAL.print("_VIN=");
    PC_SERIAL.print(telemetry.inputVoltage, 1);

    PC_SERIAL.print(",");
    PC_SERIAL.print(prefix);
    PC_SERIAL.print("_TACH=");
    PC_SERIAL.print(telemetry.tachometer);
  }
}

void sendTelemetryFrame() {
  readCanBus();

  if (DRY_RUN) {
    PC_SERIAL.println("<TEL,DRY=1>");
    return;
  }

  PC_SERIAL.print("<TEL,CAN_READY=");
  PC_SERIAL.print(canReady ? 1 : 0);

  printTelemetrySide("L", leftTelemetry);
  printTelemetrySide("R", rightTelemetry);

  PC_SERIAL.println(">");
}

// --------------------------------------------------
// PC protocol handler
// --------------------------------------------------

void handlePcFrame(char* frame) {
  char* cmd = strtok(frame, ",");

  if (cmd == nullptr) {
    pcErr("EMPTY_FRAME");
    return;
  }

  // <STATUS>
  if (equalsIgnoreCase(cmd, "STATUS")) {
    markValidPcCommand();
    sendStatusFrame();
    return;
  }

  // <TEL>
  if (equalsIgnoreCase(cmd, "TEL")) {
    markValidPcCommand();
    sendTelemetryFrame();
    return;
  }

  // <EN,1> or <EN,0>
  if (equalsIgnoreCase(cmd, "EN")) {
    char* arg = strtok(nullptr, ",");

    if (arg == nullptr) {
      pcErr("EN_MISSING_ARG");
      return;
    }

    if (strcmp(arg, "1") == 0) {
      enableDrive();
      return;
    }

    if (strcmp(arg, "0") == 0) {
      disableDrive();
      return;
    }

    pcErr("EN_BAD_ARG");
    return;
  }

  // After timeout, require enable again.
  if (timeoutLatched) {
    pcErr("TIMEOUT_SEND_EN_FIRST");
    return;
  }

  // <MODE,2>, <MODE,5>, <MODE,10>
  if (equalsIgnoreCase(cmd, "MODE")) {
    char* arg = strtok(nullptr, ",");

    if (arg == nullptr) {
      pcErr("MODE_MISSING_ARG");
      return;
    }

    int modeValue = atoi(arg);

    if (modeValue == 2) {
      setDrivingMode(MODE_2_KMH);
      return;
    }

    if (modeValue == 5) {
      setDrivingMode(MODE_5_KMH);
      return;
    }

    if (modeValue == 10) {
      setDrivingMode(MODE_10_KMH);
      return;
    }

    pcErr("MODE_BAD_ARG");
    return;
  }

  // <MOVE,F>, <MOVE,B>, <MOVE,L>, <MOVE,R>, <MOVE,S>
  if (equalsIgnoreCase(cmd, "MOVE")) {
    char* arg = strtok(nullptr, ",");

    if (arg == nullptr) {
      pcErr("MOVE_MISSING_ARG");
      return;
    }

    char moveCmd = toUpperChar(arg[0]);

    // This is the main command that should arrive every 50 ms.
    markValidPcCommand();

    switch (moveCmd) {
      case 'F':
        requestMotionState(FORWARD);
        pcAck("MOVE,F");
        return;

      case 'B':
        requestMotionState(REVERSE);
        pcAck("MOVE,B");
        return;

      case 'L':
        requestMotionState(LEFT);
        pcAck("MOVE,L");
        return;

      case 'R':
        requestMotionState(RIGHT);
        pcAck("MOVE,R");
        return;

      case 'S':
        requestMotionState(STOPPED);
        pcAck("MOVE,S");
        return;

      default:
        pcErr("MOVE_BAD_ARG");
        return;
    }
  }

  pcErr("UNKNOWN_CMD");
}

// --------------------------------------------------
// Serial receiving
// --------------------------------------------------

void readPcSerial() {
  while (PC_SERIAL.available() > 0) {
    char c = PC_SERIAL.read();

    if (c == '<') {
      receivingFrame = true;
      pcRxIndex = 0;
      memset(pcRxBuffer, 0, sizeof(pcRxBuffer));
      continue;
    }

    if (c == '>') {
      if (receivingFrame) {
        pcRxBuffer[pcRxIndex] = '\0';
        receivingFrame = false;
        handlePcFrame(pcRxBuffer);
      }

      continue;
    }

    if (receivingFrame) {
      if (pcRxIndex < PC_RX_BUFFER_SIZE - 1) {
        pcRxBuffer[pcRxIndex++] = c;
      } else {
        receivingFrame = false;
        pcRxIndex = 0;
        pcErr("FRAME_TOO_LONG");
      }

      continue;
    }
  }
}

// --------------------------------------------------
// PC timeout
// --------------------------------------------------

void checkPcTimeout() {
  if (!driveEnabled) {
    return;
  }

  unsigned long now = millis();

  if (now - lastValidPcCommandMs > PC_TIMEOUT_MS) {
    transitionPending = false;

    rawStopMotors();
    setMotorRelay(false);

    driveEnabled = false;
    modeSelected = false;
    timeoutLatched = true;

    pcWarn("PC_TIMEOUT_500MS");
    pcEvent("DRIVE_DISABLED_AFTER_TIMEOUT");
  }
}

// --------------------------------------------------
// CAN setup
// --------------------------------------------------

void setupCanBus() {
  if (DRY_RUN) {
    canReady = true;
    pcEvent("CAN_DRY_RUN_READY");
    return;
  }

  ACANFD_GIGA_R1_Settings settings(VESC_CAN_BITRATE, DataBitRateFactor::x1);

  settings.mModuleMode = ACANFD_GIGA_R1_Settings::NORMAL_FD;

  // VESC uses classic CAN 2.0B frames up to 8 bytes.
  settings.mHardwareRxFIFO0Payload = ACANFD_GIGA_R1_Settings::PAYLOAD_8_BYTES;
  settings.mHardwareRxFIFO1Payload = ACANFD_GIGA_R1_Settings::PAYLOAD_8_BYTES;
  settings.mHardwareTransmitBufferPayload = ACANFD_GIGA_R1_Settings::PAYLOAD_8_BYTES;

  settings.mDriverReceiveFIFO0Size = 64;
  settings.mDriverReceiveFIFO1Size = 16;
  settings.mDriverTransmitFIFOSize = 32;

  // Optional pin override examples for GIGA FDCAN1:
  // settings.mTxPin = PH_13;
  // settings.mRxPin = PH_14;
  // Default FDCAN1 pins are used if these are not set.

  uint32_t errorCode = VESC_CAN.beginFD(settings);

  PC_SERIAL.print("<BOOT,CAN_RAM_MIN_WORDS=");
  PC_SERIAL.print(VESC_CAN.messageRamRequiredMinimumSize());
  PC_SERIAL.println(">");

  if (errorCode == 0) {
    canReady = true;
    PC_SERIAL.print("<BOOT,CAN_READY,BITRATE=");
    PC_SERIAL.print(VESC_CAN_BITRATE);
    PC_SERIAL.println(">");
  } else {
    canReady = false;
    PC_SERIAL.print("<BOOT,CAN_ERROR,0x");
    PC_SERIAL.print(errorCode, HEX);
    PC_SERIAL.println(">");
  }
}

// --------------------------------------------------
// Setup and loop
// --------------------------------------------------

void setup() {
  PC_SERIAL.begin(115200);
  while (!PC_SERIAL) {;}

  PC_SERIAL.println();
  PC_SERIAL.println("<BOOT,CHAIR_CAN_PROTOCOL_READY>");
  PC_SERIAL.print("<BOOT,EXPECTED_COMMAND_PERIOD_MS=");
  PC_SERIAL.print(EXPECTED_PC_COMMAND_PERIOD_MS);
  PC_SERIAL.println(">");
  PC_SERIAL.print("<BOOT,TIMEOUT_MS=");
  PC_SERIAL.print(PC_TIMEOUT_MS);
  PC_SERIAL.println(">");
  PC_SERIAL.print("<BOOT,DRY_RUN=");
  PC_SERIAL.print(DRY_RUN ? 1 : 0);
  PC_SERIAL.println(">");
  PC_SERIAL.print("<BOOT,LEFT_VESC_ID=");
  PC_SERIAL.print(LEFT_VESC_ID);
  PC_SERIAL.println(">");
  PC_SERIAL.print("<BOOT,RIGHT_VESC_ID=");
  PC_SERIAL.print(RIGHT_VESC_ID);
  PC_SERIAL.println(">");

  setupMotorRelay();
  setupCanBus();

  lastValidPcCommandMs = millis();

  rawStopMotors();
  sendStatusFrame();
}

void loop() {
  readPcSerial();

  readCanBus();

  processPendingTransition();

  checkPcTimeout();

  if (driveEnabled && (millis() - lastKeepAliveMs > KEEPALIVE_MS)) {
    lastKeepAliveMs = millis();
    sendKeepaliveBoth();
  }
}
